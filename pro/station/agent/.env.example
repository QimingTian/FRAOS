# Queue / hub auth (same secret as PERSONAL_TENANT_SECRETS / tenant apiSecret)
IMAGING_QUEUE_SECRET=YOUR_API_SECRET

# Cloudflare R2 (optional — for cloud file upload)
PERSONAL_R2_ENABLED=0
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://files.YOUR_DOMAIN
R2_PREFIX=imaging
