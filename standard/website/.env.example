# Upstash / Vercel KV
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Tenant auth — JSON map of tenantId → Bearer secret
PERSONAL_TENANT_SECRETS={"YOUR_TENANT_ID":"YOUR_API_SECRET"}
PERSONAL_DEV_TENANT_SECRET=YOUR_API_SECRET

# Optional promo codes JSON
PERSONAL_PROMO_CODES={"YOUR_PROMO_CODE":{"plan":"standard","days":30}}

# Astrometry.net API key (nova.astrometry.net)
ASTROMETRY_API_KEY=

# Stripe (optional — card checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_BASE_URL=https://YOUR_DOMAIN

# OTA download URLs (optional)
FRAOS_STATION_DOWNLOAD_URL_WINDOWS=
FRAOS_CONTROL_DOWNLOAD_URL_WINDOWS=
FRAOS_CONTROL_DOWNLOAD_URL_MAC=
STATION_LATEST_VERSION=
CONTROL_LATEST_VERSION=

# Public site URL (marketing + absolute links)
NEXT_PUBLIC_SITE_URL=https://YOUR_DOMAIN
BOREAN_API_BASE_URL=https://YOUR_DOMAIN

# Email (optional)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=FRAOS <noreply@YOUR_DOMAIN>
